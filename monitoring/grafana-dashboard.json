  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Количество HTTP-запросов в секунду к FastAPI",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "list"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{job=\"fastapi\"}[1m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "FastAPI: запросов/с по эндпоинтам",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "P95 латентность по эндпоинтам",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "list"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])))",
          "legendFormat": "p95 {{handler}}",
          "refId": "A"
        }
      ],
      "title": "FastAPI: p95 latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Доля 4xx/5xx",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 30, "lineWidth": 2},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "legend": {"calcs": ["mean", "last"], "displayMode": "list"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi\",status=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total{job=\"fastapi\"}[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "title": "FastAPI: error rate (4xx/5xx)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Использование CPU контейнерами",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "list"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"vkr-.*\"}[1m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "cAdvisor: CPU контейнеров (%)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Использование памяти контейнерами",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2},
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "list"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"vkr-.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "cAdvisor: память контейнеров",
      "type": "timeseries"
    }
  ],
