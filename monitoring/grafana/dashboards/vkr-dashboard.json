    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Запросов в секунду в разрезе эндпоинтов API: /predict (главная функция), /health (проверка), /metrics (этот же дашборд для Prometheus), /experiments, /system/containers, /train. Стек показывает суммарную нагрузку. Полезно увидеть, какой эндпоинт самый нагруженный.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal"}
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (handler) (rate(http_requests_total{job=\"fastapi\"}[1m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "RPS по эндпоинтам",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
