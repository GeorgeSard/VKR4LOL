      "panels": [],
      "title": "Общие показатели — текущее состояние API",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Сколько HTTP-запросов в секунду сейчас обрабатывает FastAPI (среднее за последнюю минуту). Считается по всем эндпоинтам. Метрика: rate(http_requests_total). Пороги: 0–10 норма, 10–50 повышенная нагрузка, >50 высокая.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{job=\"fastapi\"}[1m]))",
          "refId": "A"
        }
      ],
      "title": "Общий RPS",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "P95 латентность: 95% запросов завершаются быстрее этого значения. Окно усреднения 5 минут. Зелёный <100ms, жёлтый <500ms, красный >500ms. Запросы /predict обычно 5-50ms на CPU.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "P95 latency",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Доля HTTP-ответов с кодами 4xx (ошибки клиента) и 5xx (ошибки сервера) от общего числа за 5 минут. Здоровый сервис <1%. Если растёт — смотри логи fastapi: docker compose logs -f fastapi.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{job=\"fastapi\",status=~\"4..|5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"fastapi\"}[5m])), 0.001)",
          "refId": "A"
        }
      ],
      "title": "Error rate",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "x": 0,
